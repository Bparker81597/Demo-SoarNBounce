---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Soar N Bounce Grandville | Jump, Play, Celebrate">
  <!-- 1. HERO SECTION -->
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="/Demo-SoarNBounce/images/hero-header.png" 
        alt="Kids jumping at Soar N Bounce" 
        class="w-full h-full object-cover opacity-60 scale-105"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/40 to-transparent"></div>
    </div>
    
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <h1 class="text-5xl md:text-8xl font-headings font-black italic mb-4 tracking-tighter text-white">
        SOAR <span class="text-primary">'N</span> BOUNCE <br/>
        <span class="text-secondary text-4xl md:text-6xl not-italic uppercase tracking-widest block mt-4">Grandville</span>
      </h1>
      <p class="text-xl md:text-3xl font-bold text-gray-200 mb-10 uppercase tracking-[0.2em]">
        Jump • Play • Celebrate
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/Demo-SoarNBounce/book" class="bg-primary hover:bg-blue-600 text-white text-xl px-10 py-5 rounded-full font-black uppercase transition-all shadow-xl shadow-primary/30 hover:scale-105">
          Book Jump Time
        </a>
        <a href="/Demo-SoarNBounce/parties" class="bg-accent hover:bg-orange-600 text-white text-xl px-10 py-5 rounded-full font-black uppercase transition-all shadow-xl shadow-accent/30 hover:scale-105">
          Birthday Parties
        </a>
      </div>

      <div class="mt-12 flex justify-center space-x-8 text-sm font-bold uppercase tracking-widest text-gray-400">
        <a href="/Demo-SoarNBounce/pricing" class="hover:text-white transition-colors">Hours</a>
        <span>|</span>
        <a href="/Demo-SoarNBounce/pricing" class="hover:text-white transition-colors">Pricing</a>
        <span>|</span>
        <a href="/Demo-SoarNBounce/waiver" class="hover:text-white transition-colors text-secondary">Sign Waiver</a>
      </div>
    </div>
  </section>

  <!-- 2. QUICK INFO CARDS -->
  <section class="max-w-7xl mx-auto px-6 -mt-16 relative z-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white/5 backdrop-blur-xl p-8 rounded-3xl border border-white/10 shadow-2xl hover:border-primary/50 transition-colors group">
        <div class="text-primary text-3xl mb-4 group-hover:scale-110 transition-transform">🕒</div>
        <h3 class="text-gray-400 uppercase font-bold text-xs tracking-widest mb-2">Hours Today</h3>
        <p class="text-2xl font-bold">10AM – 9PM</p>
      </div>
      <div class="bg-white/5 backdrop-blur-xl p-8 rounded-3xl border border-white/10 shadow-2xl hover:border-secondary/50 transition-colors group">
        <div class="text-secondary text-3xl mb-4 group-hover:scale-110 transition-transform">💰</div>
        <h3 class="text-gray-400 uppercase font-bold text-xs tracking-widest mb-2">Prices</h3>
        <p class="text-2xl font-bold">$18 <span class="text-sm font-normal text-gray-500">/ 90 mins</span></p>
      </div>
      <div class="bg-white/5 backdrop-blur-xl p-8 rounded-3xl border border-white/10 shadow-2xl hover:border-accent/50 transition-colors group">
        <div class="text-accent text-3xl mb-4 group-hover:scale-110 transition-transform">📝</div>
        <h3 class="text-gray-400 uppercase font-bold text-xs tracking-widest mb-2">Waiver</h3>
        <p class="text-2xl font-bold text-secondary italic">Sign Online</p>
      </div>
      <div class="bg-white/5 backdrop-blur-xl p-8 rounded-3xl border border-white/10 shadow-2xl hover:border-white/50 transition-colors group">
        <div class="text-white text-3xl mb-4 group-hover:scale-110 transition-transform">📍</div>
        <h3 class="text-gray-400 uppercase font-bold text-xs tracking-widest mb-2">Location</h3>
        <p class="text-2xl font-bold">Grandville, MI</p>
      </div>
    </div>
  </section>

  <!-- 3. ATTRACTIONS GRID -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-headings font-black italic uppercase tracking-tighter mb-4">
        EPIC <span class="text-primary">ATTRACTIONS</span>
      </h2>
      <p class="text-gray-400 max-w-2xl mx-auto">Discover a world of high-flying excitement with our state-of-the-art attractions designed for all ages.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        [
          { name: 'Trampolines', desc: 'Wall-to-wall bouncing fun for everyone.', color: 'primary' },
          { name: 'Dodgeball', desc: 'Ultimate team challenges on trampolines.', color: 'accent' },
          { name: 'Ninja Course', desc: 'Test your strength and agility.', color: 'secondary' },
          { name: 'Foam Pit', desc: 'Soft landings for your biggest tricks.', color: 'primary' },
          { name: 'Kids Zone', desc: 'Safe play area for our smallest jumpers.', color: 'accent' },
          { name: 'Climbing Wall', desc: 'Reach new heights on our vertical walls.', color: 'secondary' }
        ].map((item) => (
          <div class="group relative overflow-hidden rounded-[2rem] bg-gray-900 aspect-square flex flex-col justify-end p-8 border border-white/5 hover:border-primary/20 transition-all">
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent z-10"></div>
            <!-- Placeholder for image -->
            <div class={`absolute inset-0 bg-${item.color}/10 group-hover:bg-${item.color}/20 transition-colors`}></div>
            
            <div class="relative z-20">
              <h3 class={`text-3xl font-headings font-bold italic uppercase mb-2 text-${item.color}`}>
                {item.name}
              </h3>
              <p class="text-gray-400 mb-6 group-hover:text-white transition-colors">{item.desc}</p>
              <button class="text-white font-bold text-sm uppercase tracking-widest border-b-2 border-white/20 pb-1 hover:border-white transition-all">
                Learn More
              </button>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 4. BIRTHDAY PARTY SECTION -->
  <section class="bg-accent/10 py-24 px-6 my-12 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-[120px] -mr-48 -mt-48"></div>
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-5xl md:text-7xl font-headings font-black italic uppercase tracking-tighter mb-8 leading-tight">
          BIRTHDAY <br/>
          <span class="text-accent">PARTIES</span>
        </h2>
        <p class="text-2xl font-bold mb-8 text-white uppercase tracking-widest">Celebrate with us!</p>
        
        <ul class="space-y-6 mb-12">
          <li class="flex items-center space-x-4 text-xl">
             <span class="bg-accent/20 p-2 rounded-lg text-accent">✔</span>
             <span class="font-bold">Jump time included for all guests</span>
          </li>
          <li class="flex items-center space-x-4 text-xl">
             <span class="bg-accent/20 p-2 rounded-lg text-accent">✔</span>
             <span class="font-bold">Private table & dedicated host</span>
          </li>
          <li class="flex items-center space-x-4 text-xl">
             <span class="bg-accent/20 p-2 rounded-lg text-accent">✔</span>
             <span class="font-bold">Pizza, drinks, and party favors</span>
          </li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-6">
          <a href="/Demo-SoarNBounce/parties" class="bg-accent hover:bg-orange-600 text-white text-center px-10 py-5 rounded-full font-black uppercase transition-all shadow-xl shadow-accent/20">
            View Party Packages
          </a>
          <a href="/Demo-SoarNBounce/book" class="bg-white hover:bg-gray-100 text-black text-center px-10 py-5 rounded-full font-black uppercase transition-all shadow-xl">
            Book Party
          </a>
        </div>
      </div>
      <div class="relative">
         <div class="aspect-video bg-gray-800 rounded-[3rem] shadow-2xl overflow-hidden border-8 border-white/5 relative">
            <div class="absolute inset-0 flex items-center justify-center text-4xl opacity-20">🎂 PARTY IMAGE</div>
            <!-- In a real app, this would be a vibrant party image -->
            <div class="absolute inset-0 bg-gradient-to-tr from-accent/20 to-transparent"></div>
         </div>
         <div class="absolute -bottom-8 -left-8 bg-primary p-8 rounded-3xl shadow-2xl rotate-3">
            <p class="text-white font-black italic text-2xl uppercase">Hassle-Free!</p>
            <p class="text-blue-100 text-sm font-bold">We handle the cleanup.</p>
         </div>
      </div>
    </div>
  </section>

  <!-- 5. GROUP EVENTS -->
  <section class="max-w-7xl mx-auto px-6 py-24">
    <div class="bg-white/5 rounded-[4rem] p-12 md:p-24 border border-white/10 relative overflow-hidden">
       <div class="relative z-10 text-center max-w-3xl mx-auto">
          <h2 class="text-4xl md:text-5xl font-headings font-black italic uppercase mb-8">GROUP EVENTS</h2>
          <div class="flex flex-wrap justify-center gap-12 mb-12">
             <div class="text-center">
                <div class="text-4xl mb-2">🚌</div>
                <h4 class="font-bold text-secondary uppercase tracking-widest">Field Trips</h4>
             </div>
             <div class="text-center">
                <div class="text-4xl mb-2">💼</div>
                <h4 class="font-bold text-primary uppercase tracking-widest">Corporate</h4>
             </div>
             <div class="text-center">
                <div class="text-4xl mb-2">⚽</div>
                <h4 class="font-bold text-accent uppercase tracking-widest">Team Parties</h4>
             </div>
          </div>
          <p class="text-gray-400 mb-10 text-lg">Looking for a unique venue for your next group outing? We offer customized packages for groups of 15 or more!</p>
          <a href="/Demo-SoarNBounce/events" class="inline-block border-2 border-white hover:bg-white hover:text-black transition-all px-10 py-4 rounded-full font-black uppercase">
             Inquire Now
          </a>
       </div>
    </div>
  </section>
</Layout>
